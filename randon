.term-type-card__header {
  margin-bottom: 0.5rem;

  // Reset pvd-title default margin for compact card layout
  ::ng-deep .pvd-title__heading {
    margin: 0;
  }
}

.term-type-card__prompt {
  display: block;
  margin: 0;
}

.term-type-card__options {
  margin-top: 0.75rem;
}

// cursor: not-allowed on parent, pointer-events: none on children
// so disabled cursor is visible but clicks are blocked
.term-type-card__option-row--disabled {
  cursor: not-allowed;
  opacity: 0.6;

  & * {
    pointer-events: none;
  }
}