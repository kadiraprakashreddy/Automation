import { Router, RouterOutlet } from '@angular/router';
import {
  ChangeDetectionStrategy,
  Component,
  OnInit,
  inject,
} from '@angular/core';
import { DOCUMENT } from '@angular/common';
import { EntryContextService } from './utils/entry-context.service';
@Component({
  selector: 'sps-termination-terminations-root',
  templateUrl: './root.component.html',
  styleUrl: './root.component.scss',
  imports: [RouterOutlet],
  changeDetection: ChangeDetectionStrategy.OnPush,
})
export class RootComponent implements OnInit {
  private readonly router = inject(Router);
  private readonly entryContextService = inject(EntryContextService);

  ngOnInit(): void {
    const isRootEntry = !this.router.url
      || this.router.url === '/'
      || this.router.url === '/terminations';

    if (!isRootEntry) {
      return; // preserve deep links
    }

    this.router.navigateByUrl(
      this.entryContextService.defaultRoute,
      { replaceUrl: true }
    );
  }
}