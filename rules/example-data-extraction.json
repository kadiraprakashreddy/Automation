{
  "name": "Product Data Extraction",
  "description": "Extract product information from an e-commerce website",
  "continueOnError": true,
  "steps": [
    {
      "stepId": "1",
      "action": "navigate",
      "enabled": true,
      "url": "https://example.com/products",
      "waitUntil": "domcontentloaded",
      "description": "Navigate to products page"
    },
    {
      "stepId": "2",
      "action": "waitForSelector",
      "enabled": true,
      "selector": ".product-list",
      "state": "visible",
      "description": "Wait for product list to load"
    },
    {
      "stepId": "3",
      "action": "extractText",
      "enabled": true,
      "selector": ".product-item:first-child .product-name",
      "storeAs": "firstProductName",
      "description": "Extract first product name"
    },
    {
      "stepId": "4",
      "action": "extractText",
      "enabled": true,
      "selector": ".product-item:first-child .product-price",
      "storeAs": "firstProductPrice",
      "description": "Extract first product price"
    },
    {
      "stepId": "5",
      "action": "extractAttribute",
      "enabled": true,
      "selector": ".product-item:first-child img",
      "attribute": "src",
      "storeAs": "firstProductImage",
      "description": "Extract first product image URL"
    },
    {
      "stepId": "6",
      "action": "click",
      "enabled": true,
      "selector": ".product-item:first-child",
      "description": "Click on first product"
    },
    {
      "stepId": "7",
      "action": "waitForSelector",
      "enabled": true,
      "selector": ".product-details",
      "state": "visible",
      "description": "Wait for product details to load"
    },
    {
      "stepId": "8",
      "action": "extractText",
      "enabled": true,
      "selector": ".product-description",
      "storeAs": "productDescription",
      "description": "Extract product description"
    },
    {
      "stepId": "9",
      "action": "extractText",
      "enabled": true,
      "selector": ".product-rating",
      "storeAs": "productRating",
      "description": "Extract product rating"
    },
    {
      "stepId": "10",
      "action": "evaluate",
      "enabled": true,
      "script": "document.querySelectorAll('.product-reviews .review-item').length",
      "storeAs": "reviewCount",
      "description": "Count number of reviews using JavaScript"
    },
    {
      "stepId": "11",
      "action": "screenshot",
      "enabled": true,
      "filename": "product-details.png",
      "fullPage": true,
      "description": "Capture product details page"
    }
  ]
}

