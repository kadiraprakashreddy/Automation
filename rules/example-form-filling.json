{
  "name": "Contact Form Submission",
  "description": "Automated form filling and submission workflow",
  "continueOnError": false,
  "steps": [
    {
      "stepId": "1",
      "action": "navigate",
      "enabled": true,
      "url": "https://example.com/contact",
      "waitUntil": "domcontentloaded",
      "description": "Navigate to contact form page"
    },
    {
      "stepId": "2",
      "action": "waitForSelector",
      "enabled": true,
      "selector": "#contact-form",
      "state": "visible",
      "description": "Wait for contact form to be visible"
    },
    {
      "stepId": "3",
      "action": "fill",
      "enabled": true,
      "selector": "#name",
      "text": "John Doe",
      "description": "Fill in name field"
    },
    {
      "stepId": "4",
      "action": "fill",
      "enabled": true,
      "selector": "#email",
      "text": "john.doe@example.com",
      "description": "Fill in email field"
    },
    {
      "stepId": "5",
      "action": "fill",
      "enabled": true,
      "selector": "#phone",
      "text": "+1-555-0123",
      "description": "Fill in phone number"
    },
    {
      "stepId": "6",
      "action": "select",
      "enabled": true,
      "selector": "#subject",
      "value": "general-inquiry",
      "description": "Select subject from dropdown"
    },
    {
      "stepId": "7",
      "action": "type",
      "enabled": true,
      "selector": "#message",
      "text": "This is an automated test message. Please disregard.",
      "delay": 50,
      "description": "Type message with realistic delay"
    },
    {
      "stepId": "8",
      "action": "check",
      "enabled": true,
      "selector": "#agree-terms",
      "description": "Check terms and conditions checkbox"
    },
    {
      "stepId": "9",
      "action": "hover",
      "enabled": true,
      "selector": "button[type='submit']",
      "description": "Hover over submit button"
    },
    {
      "stepId": "10",
      "action": "screenshot",
      "enabled": true,
      "filename": "form-before-submit.png",
      "fullPage": false,
      "description": "Take screenshot before submission"
    },
    {
      "stepId": "11",
      "action": "click",
      "enabled": false,
      "selector": "button[type='submit']",
      "description": "Submit the form (disabled for safety)"
    },
    {
      "stepId": "12",
      "action": "waitForSelector",
      "enabled": false,
      "selector": ".success-message",
      "state": "visible",
      "timeout": 10000,
      "description": "Wait for success message"
    },
    {
      "stepId": "13",
      "action": "extractText",
      "enabled": false,
      "selector": ".success-message",
      "storeAs": "confirmationMessage",
      "description": "Extract confirmation message"
    }
  ]
}

