{
  "name": "Google Search Demo",
  "description": "A simple demo that searches Google and captures results - works without login credentials",
  "continueOnError": false,
  "steps": [
    {
      "stepId": "1",
      "action": "navigate",
      "enabled": true,
      "url": "https://www.google.com",
      "waitUntil": "domcontentloaded",
      "description": "Navigate to Google homepage"
    },
    {
      "stepId": "2",
      "action": "waitForSelector",
      "enabled": true,
      "selector": "textarea[name='q']",
      "state": "visible",
      "description": "Wait for search input to be visible"
    },
    {
      "stepId": "3",
      "action": "screenshot",
      "enabled": true,
      "filename": "01-google-homepage.png",
      "fullPage": false,
      "description": "Capture Google homepage"
    },
    {
      "stepId": "4",
      "action": "fill",
      "enabled": true,
      "selector": "textarea[name='q']",
      "text": "Playwright automation",
      "description": "Enter search query"
    },
    {
      "stepId": "5",
      "action": "wait",
      "enabled": true,
      "duration": 1000,
      "description": "Wait for autocomplete"
    },
    {
      "stepId": "6",
      "action": "click",
      "enabled": true,
      "selector": "input[name='btnK']",
      "description": "Click Google Search button"
    },
    {
      "stepId": "7",
      "action": "waitForSelector",
      "enabled": true,
      "selector": "#search",
      "state": "visible",
      "timeout": 10000,
      "description": "Wait for search results"
    },
    {
      "stepId": "8",
      "action": "extractText",
      "enabled": true,
      "selector": "#result-stats",
      "storeAs": "resultStats",
      "description": "Extract result statistics"
    },
    {
      "stepId": "9",
      "action": "evaluate",
      "enabled": true,
      "script": "document.querySelectorAll('#search .g').length",
      "storeAs": "resultCount",
      "description": "Count number of search results on first page"
    },
    {
      "stepId": "10",
      "action": "screenshot",
      "enabled": true,
      "filename": "02-search-results.png",
      "fullPage": true,
      "description": "Capture search results page"
    },
    {
      "stepId": "11",
      "action": "extractText",
      "enabled": true,
      "selector": "#search .g:first-child h3",
      "storeAs": "firstResultTitle",
      "description": "Extract first result title"
    },
    {
      "stepId": "12",
      "action": "wait",
      "enabled": true,
      "duration": 2000,
      "description": "Pause to view results"
    }
  ]
}

