{
  "name": "Advanced Automation Features",
  "description": "Demonstrates advanced features like data reuse, custom scripts, and conditional execution",
  "continueOnError": true,
  "steps": [
    {
      "stepId": "1",
      "action": "navigate",
      "enabled": true,
      "url": "https://example.com",
      "waitUntil": "networkidle",
      "description": "Navigate to home page"
    },
    {
      "stepId": "2",
      "action": "evaluate",
      "enabled": true,
      "script": "document.title",
      "storeAs": "pageTitle",
      "description": "Extract page title using JavaScript"
    },
    {
      "stepId": "3",
      "action": "evaluate",
      "enabled": true,
      "script": "window.location.href",
      "storeAs": "currentUrl",
      "description": "Store current URL"
    },
    {
      "stepId": "4",
      "action": "extractText",
      "enabled": true,
      "selector": "h1",
      "storeAs": "mainHeading",
      "description": "Extract main heading"
    },
    {
      "stepId": "5",
      "action": "screenshot",
      "enabled": true,
      "filename": "homepage-initial.png",
      "fullPage": true,
      "description": "Capture homepage"
    },
    {
      "stepId": "6",
      "action": "hover",
      "enabled": true,
      "selector": "nav .dropdown-menu",
      "description": "Hover to reveal dropdown menu"
    },
    {
      "stepId": "7",
      "action": "wait",
      "enabled": true,
      "duration": 1000,
      "description": "Wait for dropdown animation"
    },
    {
      "stepId": "8",
      "action": "click",
      "enabled": true,
      "selector": "nav .dropdown-menu a:first-child",
      "description": "Click first dropdown item"
    },
    {
      "stepId": "9",
      "action": "waitForNavigation",
      "enabled": true,
      "waitUntil": "domcontentloaded",
      "description": "Wait for new page to load"
    },
    {
      "stepId": "10",
      "action": "evaluate",
      "enabled": true,
      "script": "document.querySelectorAll('a').length",
      "storeAs": "linkCount",
      "description": "Count total links on page"
    },
    {
      "stepId": "11",
      "action": "extractAttribute",
      "enabled": true,
      "selector": "link[rel='canonical']",
      "attribute": "href",
      "storeAs": "canonicalUrl",
      "description": "Extract canonical URL"
    },
    {
      "stepId": "12",
      "action": "screenshot",
      "enabled": true,
      "filename": "final-page.png",
      "fullPage": true,
      "description": "Final screenshot",
      "delayAfter": 2000
    }
  ]
}

