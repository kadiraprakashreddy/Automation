{
  "name": "User Authentication and Course Search Workflow",
  "version": "1.0.0",
  "author": "Prakash Reddy K",
  "created": "2025-10-19",
  "networkActivity": false,
  "continueOnError": false,
  "steps": [
    {
      "stepId": "nav-login-page",
      "action": "navigate",
      "url": "https://snackoverflowdemo.dev1.reliaslearning.com",
      "waitUntil": "domcontentloaded"
    },
    {
      "stepId": "wait-page-load",
      "action": "wait",
      "duration": 3000
    },
    {
      "stepId": "capture-login-page",
      "action": "screenshot",
      "enabled": false,
      "fullPage": true
    },
    {
      "stepId": "fill-username",
      "action": "fill",
      "selector": "#Username",
      "text": "praksah444499"
    },
    {
      "stepId": "fill-password",
      "action": "fill",
      "selector": "#Password",
      "text": "Demo@12345"
    },
    {
      "stepId": "capture-filled-form",
      "action": "screenshot",
      "enabled": false,
      "fullPage": false
    },
    {
      "stepId": "click-login-button",
      "action": "click",
      "selector": "button[type='submit']"
    },
    {
      "stepId": "wait-login-complete",
      "action": "wait",
      "duration": 2000
    },
    {
      "stepId": "click-learning-menu",
      "action": "click",
      "selector": "button[type='button'][aria-controls='learningMenu']"
    },
    {
      "stepId": "wait-menu-expand",
      "action": "wait",
      "duration": 1000
    },
    {
      "stepId": "click-modules-link",
      "action": "click",
      "selector": "#FormContentPlaceHolder_LeftHandNav_ModulesLink"
    },
    {
      "stepId": "8d",
      "action": "wait",
      "duration": 1500
    },
    {
      "stepId": "8e",
      "action": "click",
      "selector": "[data-cy='lhn-module-list']"
    },
    {
      "stepId": "8f",
      "action": "wait",
      "duration": 1000
    },
    {
      "stepId": "nav-content-library",
      "action": "navigate",
      "url": "https://snackoverflowdemo.dev1.reliaslearning.com/new/en/content-library",
      "waitUntil": "domcontentloaded"
    },
    {
      "stepId": "8h",
      "action": "wait",
      "duration": 3000
    },
    {
      "stepId": "click-courses-tile",
      "action": "click",
      "selector": "mat-card-title.content-library-tile-text:has-text('Courses')"
    },
    {
      "stepId": "8h2",
      "action": "wait",
      "duration": 2000
    },
    {
      "stepId": "8i",
      "action": "screenshot",
      "enabled": false,
      "fullPage": true
    },
    {
      "stepId": "8j",
      "action": "wait",
      "duration": 3000
    },
    {
      "stepId": "search-courses",
      "action": "fill",
      "selector": "[placeholder='Search courses']",
      "text": "reddy"
    },
    {
      "stepId": "8l",
      "action": "wait",
      "duration": 2000
    },
    {
      "stepId": "click-course-reddy123",
      "action": "click",
      "selector": "[data-cy='course-title']:has-text('Reddy123')"
    },
    {
      "stepId": "8n",
      "action": "wait",
      "duration": 3000
    },
    {
      "stepId": "8n1",
      "action": "screenshot",
      "enabled": false,
      "fullPage": true
    },
    {
      "stepId": "11",
      "action": "validate",
      "validationType": "exists",
      "selector": "mat-tab-header.mat-mdc-tab-header"
    },
    {
      "stepId": "11-check-overview",
      "action": "validate",
      "validationType": "textContains",
      "selector": "mat-tab-header.mat-mdc-tab-header",
      "expectedValue": "Overview123",
      "continueOnError": true,
      "script": "validate('Missing tab: Overview', 'error')"
    },
    {
      "stepId": "11-check-outline",
      "action": "validate",
      "validationType": "textContains",
      "selector": "mat-tab-header.mat-mdc-tab-header",
      "expectedValue": "Outline",
      "continueOnError": true,
      "script": "validate('Missing tab: Outline', 'error')"
    },
    {
      "stepId": "12-check-course-description",
      "action": "validate",
      "validationType": "textContains",
      "selector": "relias-shared-course-overview-tab",
      "expectedValue": "prakash testing123",
      "continueOnError": true,
      "script": "validate('Course Description missing: prakash testing', 'error')"
    },
    {
      "stepId": "End-of-test",
      "action": "wait",
      "duration": 600000
    }
  ]
}