                            "paragraphs": [
                                {
                                    "type": "STRING",
                                    "value": "<ul xmlns=\"http://www.w3.org/1999/xhtml\"><li>Plan Sponsor Announcement*: <a href=\"http://workplaceservices.fidelity.com/bin-public/070_NB_SPS_Pages/documents/dcl/shared/StockPlanServices/SPS_DOMPSA_SAM.pdf\" id=\"Link_1632235560128\" title=\"US\" target=\"_blank\" name=\"Link_1632235560128\" >US</a> | <a href=\"http://workplaceservices.fidelity.com/bin-public/070_NB_SPS_Pages/documents/dcl/shared/StockPlanServices/SPS_INTPSA_SAM.pdf\" id=\"Link_1632235617834\" title=\"Outside US\" target=\"_blank\" name=\"Link_1632235617834\" >Outside US</a></li></ul>"
                                }
