{
  "name": "psw-library-client-app",
  "version": "1.0.0",
  "scripts": {
    "ng": "ng",
    "start": "echo '`npm start` no longer used' && exit 0",
    "dev": "concurrently \"ng serve\" \"npm run demo-server\"",
    "dev:internal": "concurrently \"ng serve --host=0.0.0.0\" \"npm run demo-server\"",
    "dev:https": "ng serve --ssl",
    "dev:prod": "concurrently \"ng serve --configuration production\" \"npm run demo-server\"",
    "dev:prod:https": "ng serve --ssl --configuration production --host=0.0.0.0",
    "demo-server": "node ./demo/demo-server.js",
    "build": "npm run lint && ng build --stats-json && npm run gzip:build && npm run zip:build",
    "zip:build": "npx dp-ng-zip dist/pswLibraryClientAppContent",
    "gzip:build": "npx dp-ng-zip dist/pswLibraryClientAppContent",
    "report": "webpack-bundle-analyzer dist/pswLibraryClientAppContent/stats.json -p 8888",
    "report:source-map": "source-map-explorer dist/pswLibraryClientAppContent/*.js",
    "test": "echo 'use `npm run test:unit` or `npm run test:e2e` or `npm run test:accessibility` instead' && exit 0",
    "test:unit": "jest --watchAll",
    "test:unit:CICD": "jest --runInBand --ci",
    "test:unit:singlerun": "jest --watchAll=false",
    "test:e2e": "playwright test --headed",
    "test:e2e:debug": "cross-env PWDEBUG=1 playwright test --headed",
    "test:e2e:CICD": "playwright test --project chrome",
    "test:accessibility": "echo TODO ADD ACCESSIBILITY TESTING",
    "lint": "npm run stylelint && ng lint --fix",
    "stylelint": "stylelint \"src/**/*.scss\" --fix",
    "e2e": "echo 'use `npm run test:e2e` instead' && exit 0",
    "build:source-map": "ng build --stats-json --sourceMap=true",
    "prereport:source-map": "npm run build:source-map",
    "prereport": "npm run build:source-map",
    "pretest:e2e": "node ./node_modules/protractor/bin/webdriver-manager update --verbose --standalone=false  --gecko=false --chrome --ignore_ssl --proxy=http://http.proxy.fmr.com:8000"
  },
  "author": "",
  "contributors": [],
  "private": true,
  "dependencies": {
    "@angular/animations": "^21.2.5",
    "@angular/forms": "^21.2.5",
    "@angular/platform-browser": "^21.2.5",
    "@angular/platform-browser-dynamic": "^21.2.5",
    "@angular/router": "^21.2.5",
    "@webcomponents/webcomponentsjs": "2.8.0",
    "bootstrap": "^5.3.3",
    "i": "^0.3.7",
    "jest-preset-angular": "^14.6.1",
    "npm": "^11.7.0",
    "rxjs": "^7.8.1",
    "ts-jest": "^29.4.4",
    "tslib": "^2.8.1",
    "zone.js": "^0.15.1"
  },
  "devDependencies": {
    "@angular-builders/jest": "^21.0.3",
    "@angular-devkit/build-angular": "^21.2.3",
    "@angular/cli": "^21.2.3",
    "@angular/common": "^21.2.5",
    "@angular/compiler": "^21.2.5",
    "@angular/compiler-cli": "^21.2.5",
    "@angular/core": "^21.2.5",
    "@playwright/test": "^1.56.1",
    "@types/events": "^3.0.2",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.9.2",
    "@types/trusted-types": "^2.0.7",
    "archiver": "^7.0.1",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "express": "^4.19.2",
    "glob": "^11.0.3",
    "husky": "^9.1.7",
    "jest": "^30.0.0",
    "jest-environment-jsdom": "^30.0.0",
    "jest-preset-angular": "^16.1.1",
    "jsdom": "^26.0.0",
    "kleur": "^4.1.5",
    "mkdirp": "^3.0.1",
    "msw": "^1.3.3",
    "postcss": "^8.5.6",
    "source-map-explorer": "^2.5.3",
    "ts-jest": "29.4.4",
    "ts-node": "^10.9.2",
    "typescript": ">5.9.0 and <6.1.0"
  },
  "optionalDependencies": {
    "@rollup/rollup-linux-x64-gnu": "*"
  },
  "overrides": {
    "brace-expansion": "5.0.4",
    "electron-to-chromium": "1.5.321"
  },
  "seed-app-version": "9.0.0",
  "engines": {
    "node": "^18.16.0"
  }
}
