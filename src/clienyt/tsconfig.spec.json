{
    "extends": "./tsconfig.json",
    "compilerOptions": {
        "outDir": "./out-tsc/spec",
        "types": ["jest", "node"],
        "module": "ES2022",
        "moduleResolution": "node16"
    },
    "include": [
        "src/jest-global-types.d.ts",
        "src/**/*.spec.ts",
        "src/**/*.d.ts",
        "src/test/**/*.ts",
        "jest.*.ts"
    ]
}
