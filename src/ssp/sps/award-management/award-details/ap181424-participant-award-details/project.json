{
  "name": "sps-award-management-award-details-ap181424-participant-award-details",
  "$schema": "../../../../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "prefix": "fmr-ap181424",
  "sourceRoot": "apps/sps/award-management/award-details/ap181424-participant-award-details/src",
  "tags": [
    "domain:sps-award-management-award-details",
    "type:application",
    "channel:web"
  ],
  "metadata": {
    "appInfo": {
      "domain": "sps/award-management/award-details",
      "reviewers": ["@TeamPeakyBlinders"],
      "appName": "ap181424-participant-award-details",
      "appId": "ap181424",
      "appType": "wiscd",
      "appVersion": "1.0.0",
