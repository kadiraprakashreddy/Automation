        "inlineStyleLanguage": "scss",
        "assets": [
          {
            "glob": "**/*",
            "input": "apps/sps/award-management/award-details/ap181424-participant-award-details/public"
          },
          {
            "glob": "mockServiceWorker.js",
            "input": "public",
            "output": "/"
          },
          {
            "glob": "**/*",
            "input": "apps/sps/award-management/award-details/ap181424-participant-award-details/env",
            "output": "/env"
          }
        ],
        "styles": [
