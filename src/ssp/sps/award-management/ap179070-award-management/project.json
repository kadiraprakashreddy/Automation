{
  "name": "sps-award-management-ap179070-award-management",
  "$schema": "../../../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "prefix": "fmr-ap179070",
  "sourceRoot": "apps/sps/award-management/ap179070-award-management/src",
  "tags": ["domain:sps-award-management", "type:application", "channel:web"],
  "metadata": {
    "appInfo": {
      "domain": "sps/award-management",
      "reviewers": ["@TeamCorleones"],
      "appName": "ap179070-award-management",
      "appId": "ap179070",
      "appType": "wiscd",
      "appVersion": "1.0.0",
      "deployEnvironments": "dev1",
      "sonarProjectKey": "com.fmr.AP179070:ap179070-award-management"
    }
  },
  "targets": {
    "build": {
      "executor": "@fmr-ap167419/tools-nx-plugin:generate-experience-config",
      "options": {
        "outputPath": "dist/apps/sps/award-management/ap179070-award-management"
      }
    },
    "build-ng": {
      "executor": "@angular/build:application",
      "outputs": ["{options.outputPath.base}"],
      "options": {
        "outputPath": {
          "base": "dist/apps/sps/award-management/ap179070-award-management",
          "browser": ""
        },
        "index": "apps/sps/award-management/ap179070-award-management/src/index.html",
        "polyfills": ["zone.js"],
        "inlineStyleLanguage": "scss",
        "assets": [
          {
            "glob": "**/*",
            "input": "apps/sps/award-management/ap179070-award-management/public"
          },
          {
            "glob": "mockServiceWorker.js",
            "input": "public",
            "output": "/"
          }
        ],
        "styles": [
          "apps/sps/award-management/ap179070-award-management/src/styles.scss"
        ],
        "scripts": [],
        "tsConfig": "apps/sps/award-management/ap179070-award-management/tsconfig.app.json",
        "browser": "apps/sps/award-management/ap179070-award-management/src/main.ts",
        "stylePreprocessorOptions": {
          "includePaths": [
            "libs/shared/design-system/ui/core/src/lib/utils",
            "node_modules"
          ]
        }
      },
      "configurations": {
        "production": {
          "budgets": [
            {
              "type": "initial",
              "maximumWarning": "600kb",
              "maximumError": "6mb"
            },
            {
              "type": "anyComponentStyle",
              "maximumWarning": "125kb",
              "maximumError": "320kb"
            }
          ],
          "outputHashing": "none",
          "fileReplacements": [
            {
              "replace": "./apps/sps/award-management/ap179070-award-management/src/environments/environment.ts",
              "with": "./apps/sps/award-management/ap179070-award-management/src/environments/environment.prod.ts"
            }
          ],
          "assets": [
            "apps/sps/award-management/ap179070-award-management/src/assets",
            "apps/sps/award-management/ap179070-award-management/src/experience.config.json"
          ],
          "deployUrl": "/static/ap179070-award-management/"
        },
        "development": {
          "optimization": false,
          "extractLicenses": false,
          "sourceMap": true
        }
      },
      "defaultConfiguration": "production"
    },
    "eslint": {
      "executor": "@nx/eslint:lint"
    },
    "extract-i18n": {
      "executor": "@angular/build:extract-i18n",
      "options": {
        "buildTarget": "sps-award-management-ap179070-award-management:build"
      }
    },
    "serve": {
      "executor": "@angular/build:dev-server",
      "configurations": {
        "production": {
          "buildTarget": "sps-award-management-ap179070-award-management:build-ng:production"
        },
        "development": {
          "buildTarget": "sps-award-management-ap179070-award-management:build-ng:development"
        }
      },
      "defaultConfiguration": "development",
      "continuous": true
    },
    "serve-static": {
      "executor": "@nx/web:file-server",
      "options": {
        "buildTarget": "award-management:build",
        "port": 4200,
        "spa": true
      }
    },
    "stylelint": {
      "executor": "nx-stylelint:lint"
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "jestConfig": "{projectRoot}/jest.config.ts"
      }
    }
  }
}
