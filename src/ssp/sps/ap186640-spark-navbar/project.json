{
  "name": "sps-ap186640-spark-navbar",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "prefix": "fmr-ap186640",
  "sourceRoot": "apps/sps/ap186640-spark-navbar/src",
  "tags": ["domain:sps", "type:application-ae", "channel:web"],
  "metadata": {
    "appInfo": {
      "domain": "sps",
      "reviewers": ["@TeamFuego"],
      "appName": "ap186640-spark-navbar",
      "appId": "ap186640",
      "appType": "wiscd",
      "appVersion": "1.0.0",
      "deployEnvironments": "dev1,acp:passive",
      "sonarProjectKey": "com.fmr.AP186640:ap186640-spark-navbar"
    }
  },
  "targets": {
    "build": {
      "executor": "@angular/build:application",
      "outputs": ["{options.outputPath.base}"],
      "options": {
        "outputPath": {
          "base": "dist/apps/sps/ap186640-spark-navbar",
          "browser": ""
        },
        "browser": "apps/sps/ap186640-spark-navbar/src/main.ts",
        "polyfills": [],
        "tsConfig": "apps/sps/ap186640-spark-navbar/tsconfig.app.json",
        "inlineStyleLanguage": "scss",
        "assets": [
          {
            "glob": "**/*",
            "input": "apps/sps/ap186640-spark-navbar/public"
          },
          {
            "glob": "mockServiceWorker.js",
            "input": "public",
            "output": "/"
          },
          {
            "glob": "**/*",
            "input": "apps/sps/ap186640-spark-navbar/env",
            "output": "/env"
          }
        ],
        "styles": ["apps/sps/ap186640-spark-navbar/src/styles.scss"]
      },
      "configurations": {
        "production": {
          "budgets": [
            {
              "type": "initial",
              "maximumWarning": "2mb",
              "maximumError": "6mb"
            },
            {
              "type": "anyComponentStyle",
              "maximumWarning": "250kb",
              "maximumError": "320kb"
            }
          ],
          "outputHashing": "none",
          "fileReplacements": [
            {
              "replace": "./apps/sps/ap186640-spark-navbar/src/environments/environment.ts",
              "with": "./apps/sps/ap186640-spark-navbar/src/environments/environment.prod.ts"
            }
          ],
          "assets": [
            "apps/sps/ap186640-spark-navbar/src/assets",
            {
              "glob": "**/*",
              "input": "apps/sps/ap186640-spark-navbar/env",
              "output": "/env"
            }
          ]
        },
        "development": {
          "optimization": false,
          "extractLicenses": false,
          "sourceMap": true
        }
      },
      "defaultConfiguration": "production"
    },
    "eslint": {
      "executor": "@nx/eslint:lint"
    },
    "extract-i18n": {
      "executor": "@angular/build:extract-i18n",
      "options": {
        "buildTarget": "sps-ap186640-spark-navbar:build"
      }
    },
    "serve": {
      "continuous": true,
      "executor": "@angular/build:dev-server",
      "configurations": {
        "production": {
          "buildTarget": "sps-ap186640-spark-navbar:build:production"
        },
        "development": {
          "buildTarget": "sps-ap186640-spark-navbar:build:development"
        }
      },
      "defaultConfiguration": "development"
    },
    "serve-static": {
      "executor": "@nx/web:file-server",
      "options": {
        "buildTarget": "sps-ap186640-spark-navbar:build",
        "port": 4200,
        "staticFilePath": "dist/apps/sps/ap186640-spark-navbar/",
        "spa": true
      }
    },
    "stylelint": {
      "executor": "nx-stylelint:lint"
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "jestConfig": "apps/sps/ap186640-spark-navbar/jest.config.ts",
        "tsConfig": "apps/sps/ap186640-spark-navbar/tsconfig.spec.json"
      }
    }
  }
}
