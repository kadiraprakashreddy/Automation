{
  "name": "sps-termination-ap184243-terminations",
  "$schema": "../../../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "prefix": "fmr-ap184243",
  "sourceRoot": "apps/sps/termination/ap184243-terminations/src",
  "tags": ["domain:sps-termination", "type:application", "channel:web"],
  "metadata": {
    "appInfo": {
      "domain": "sps/termination",
      "reviewers": ["@TeamUnited"],
      "appName": "ap184243-terminations",
      "appId": "ap184243",
      "appType": "wiscd",
      "appVersion": "1.0.0",
      "deployEnvironments": "dev1,acp:passive",
      "sonarProjectKey": "com.fmr.AP184243:ap184243-terminations"
    }
  },
  "targets": {
    "build": {
      "executor": "@angular/build:application",
      "outputs": ["{options.outputPath.base}"],
      "options": {
        "outputPath": {
          "base": "dist/apps/sps/termination/ap184243-terminations",
          "browser": ""
        },
        "browser": "apps/sps/termination/ap184243-terminations/src/main.ts",
        "polyfills": [],
        "tsConfig": "apps/sps/termination/ap184243-terminations/tsconfig.app.json",
        "inlineStyleLanguage": "scss",
        "assets": [
          {
            "glob": "**/*",
            "input": "apps/sps/termination/ap184243-terminations/public"
          },
          {
            "glob": "mockServiceWorker.js",
            "input": "public",
            "output": "/"
          },
          {
            "glob": "**/*",
            "input": "apps/sps/termination/ap184243-terminations/env",
            "output": "/env"
          }
        ],
        "styles": [
          "apps/sps/termination/ap184243-terminations/src/styles.scss",
          "libs/shared/design-system/ui/core/src/lib/utils/ds-mat-theme.scss"
        ],
        "stylePreprocessorOptions": {
          "includePaths": [
            "libs/shared/design-system/ui/core/src/lib/utils",
            "node_modules"
          ]
        }
      },
      "configurations": {
        "production": {
          "budgets": [
            {
              "type": "initial",
              "maximumWarning": "2mb",
              "maximumError": "6mb"
            },
            {
              "type": "anyComponentStyle",
              "maximumWarning": "250kb",
              "maximumError": "320kb"
            }
          ],
          "outputHashing": "none",
          "fileReplacements": [
            {
              "replace": "./apps/sps/termination/ap184243-terminations/src/environments/environment.ts",
              "with": "./apps/sps/termination/ap184243-terminations/src/environments/environment.prod.ts"
            }
          ],
          "assets": [
            "apps/sps/termination/ap184243-terminations/src/assets",
            {
              "glob": "**/*",
              "input": "apps/sps/termination/ap184243-terminations/env",
              "output": "/env"
            }
          ]
        },
        "development": {
          "optimization": false,
          "extractLicenses": false,
          "sourceMap": true
        }
      },
      "defaultConfiguration": "production"
    },
    "eslint": {
      "executor": "@nx/eslint:lint"
    },
    "extract-i18n": {
      "executor": "@angular/build:extract-i18n",
      "options": {
        "buildTarget": "sps-termination-ap184243-terminations:build"
      }
    },
    "serve": {
      "continuous": true,
      "executor": "@angular/build:dev-server",
      "configurations": {
        "production": {
          "buildTarget": "sps-termination-ap184243-terminations:build:production"
        },
        "development": {
          "buildTarget": "sps-termination-ap184243-terminations:build:development"
        }
      },
      "defaultConfiguration": "development"
    },
    "serve-static": {
      "executor": "@nx/web:file-server",
      "options": {
        "buildTarget": "sps-termination-ap184243-terminations:build",
        "port": 4200,
        "staticFilePath": "dist/apps/sps/termination/ap184243-terminations/",
        "spa": true
      }
    },
    "stylelint": {
      "executor": "nx-stylelint:lint"
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "jestConfig": "{projectRoot}/jest.config.ts"
      }
    }
  }
}
